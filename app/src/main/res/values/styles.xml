<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MyNewTime" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/burgundyRed</item>
        
        <item name="colorPrimaryDark">@color/bgDynamic</item>
        <item name="android:windowBackground">@color/bgDynamic</item>
        
        <item name="colorAccent">@color/burgundyRed</item>
        <item name="colorControlHighlight">#33888888</item>
    </style>
    
    <style name="MySpinnerPopupTheme" parent="ThemeOverlay.AppCompat.Light">
        <item name="android:popupBackground">@drawable/bg_spinner_popup</item>
        <item name="colorControlHighlight">@android:color/transparent</item>
    </style>
    
    <style name="SettingsItemStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">20dp</item>
        <item name="android:paddingVertical">16dp</item>
        <item name="android:drawablePadding">16dp</item>
        
        <item name="android:textColor">@color/textDynamic</item> 
        
        <item name="drawableTint">@color/iconTintDynamic</item>
        
        <item name="android:textSize">16sp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>
</resources>
