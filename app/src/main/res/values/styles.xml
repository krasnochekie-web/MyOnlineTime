<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Главная тема приложения. Наследуется от современного AppCompat без заголовка -->
    <style name="Theme.MyNewTime" parent="Theme.AppCompat.DayNight.NoActionBar">
        
        <!-- Основной цвет приложения (используется для кнопок, тумблеров по умолчанию) -->
        <item name="colorPrimary">@color/burgundyRed</item>
        
        <!-- Цвет верхней системной панели (где часы и батарея) -->
        <item name="colorPrimaryDark">@color/backgroundDark</item>
        
        <!-- Цвет акцента (ползунки, чекбоксы, курсор в текстовых полях) -->
        <item name="colorAccent">@color/burgundyRed</item>
        
        <!-- Цвет фона окон по умолчанию -->
        <item name="android:windowBackground">@color/backgroundDark</item>

        <!-- Отключаем системную подсветку при нажатии (так как мы делали свою в ripple) -->
        <item name="colorControlHighlight">#33FFFFFF</item>
    </style>
    <!-- Тема специально для выпадающего окна Спиннера -->
    <style name="MySpinnerPopupTheme" parent="ThemeOverlay.AppCompat.Light">
        <!-- 1. Задаем ВАШ закругленный фон для самого окна -->
        <item name="android:popupBackground">@drawable/bg_spinner_popup</item>
        
        <!-- 2. ГЛАВНОЕ: Меняем цвет системного выделения на ПРОЗРАЧНЫЙ! -->
        <!-- Это полностью убьет тот самый "старый квадратный риппл", который вам мешал -->
        <item name="colorControlHighlight">@android:color/transparent</item>
    </style>
</resources>

