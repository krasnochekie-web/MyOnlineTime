<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@android:color/transparent"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_app_card"
        android:orientation="horizontal"
        android:padding="10dp">

        <ImageView
            android:id="@+id/notif_icon_main"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_gravity="center_vertical"
            android:src="@drawable/ic_nav_time_h"
            android:tint="@color/textDynamic" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="10dp"
            android:background="@color/chartLineDynamic" />

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <!-- === 1. МАКЕТ ДЛЯ ВРЕМЕНИ === -->
            <RelativeLayout
                android:id="@+id/layout_time_notif"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="visible">

                <TextView
                    android:id="@+id/notif_text_main"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/textDynamic"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/notif_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/notif_text_main"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/textGrayDynamic"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- === 2. МАКЕТ ДЛЯ ПОДПИСЧИКОВ === -->
            <LinearLayout
                android:id="@+id/layout_follower_notif"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Карточка пользователя (более темная) -->
                <LinearLayout
                    android:id="@+id/follower_user_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_field"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="8dp"
                    android:clipToOutline="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/notif_user_avatar"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_edit_circle" />

                    <TextView
                        android:id="@+id/notif_user_nickname"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="8dp"
                        android:textColor="@color/textDynamic"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:singleLine="true" />

                    <Button
                        android:id="@+id/notif_btn_follow"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:paddingHorizontal="12dp"
                        android:background="@drawable/bg_button_grapefruit"
                        android:textColor="@color/textWhiteStatic"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:text="@string/btn_follow" />
                </LinearLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:text="@string/new_follower_title"
                        android:textColor="@color/burgundyRed"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/notif_follower_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:textColor="@color/textGrayDynamic"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </RelativeLayout>

            </LinearLayout>

        </FrameLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
