<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardBackgroundColor="@color/bgDialogDark"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Шапка без градиента (прозрачная/в цвет диалога) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:paddingHorizontal="16dp">

            <!-- Заголовок по центру -->
            <TextView
                android:id="@+id/dialog_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/action_description"
                android:textColor="@color/textWhite"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Крестик справа -->
            <ImageView
                android:id="@+id/dialog_close_btn"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="@color/textWhite" />
        </RelativeLayout>

        <!-- Поле ввода -->
        <EditText
            android:id="@+id/dialog_edit_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:backgroundTint="@color/selector_grapefruit_white"
            android:hint="@string/enter_description"
            android:textColor="@color/textWhite"
            android:textColorHint="@color/textGray"
            android:textSize="14sp" />

        <!-- Кнопка сохранить -->
        <Button
            android:id="@+id/dialog_save_btn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_button_grapefruit"
            android:text="@string/btn_save"
            android:textColor="@color/textWhite"
            android:textStyle="bold" />
    </LinearLayout>
</androidx.cardview.widget.CardView>

