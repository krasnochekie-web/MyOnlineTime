<?xml version="1.0" encoding="utf-8"?>
<!-- УБИРАЕМ paddingTop ОТСЮДА ВООБЩЕ -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgDynamic"> 

    <ProgressBar
        android:id="@+id/loading_spinner"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/grapefruit"
        android:visibility="gone" />

    <TextView
        android:id="@+id/empty_notif_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="@string/empty_notifications"
        android:textColor="@color/textGrayDynamic"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- ПЕРЕНОСИМ paddingTop СЮДА И ДОБАВЛЯЕМ clipToPadding -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_notifications"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false" 
        android:paddingTop="@dimen/header_clearance" 
        android:paddingBottom="@dimen/bottom_nav_clearance"
        android:overScrollMode="never"
        android:scrollbars="none" />

</FrameLayout>
