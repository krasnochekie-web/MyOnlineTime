<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bgDynamic"
    android:paddingTop="@dimen/header_clearance">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ProgressBar
            android:id="@+id/loading_spinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/grapefruit"
            android:visibility="visible" />

        <LinearLayout
            android:id="@+id/content_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginBottom="24dp">

                <FrameLayout
                    android:id="@+id/chart_container"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_centerInParent="true" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_centerInParent="true"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/text_total_size"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:textSize="26sp"
                        android:textColor="@color/textDynamic" />
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/unit_mb"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/textGrayDynamic" />
                </LinearLayout>
            </RelativeLayout>

            <LinearLayout
                android:id="@+id/list_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/bg_app_card"
                android:orientation="vertical"
                android:paddingVertical="8dp" />

            <Button
                android:id="@+id/btn_open_clear_modal"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp"
                android:layout_marginTop="16dp"
                android:text="@string/btn_clear_cache"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_button_grapefruit"
                android:foreground="?attr/selectableItemBackground"
                android:textStyle="bold"
                android:textSize="16sp" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
