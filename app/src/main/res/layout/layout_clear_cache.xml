<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bgDynamic"
    android:paddingTop="@dimen/header_clearance">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_app_card"
        android:orientation="vertical"
        android:paddingVertical="8dp">

        <TextView
            android:id="@+id/btn_action_clear_bg"
            style="@style/SettingsItemStyle"
            android:text="@string/settings_clear_bg"
            app:drawableStartCompat="@drawable/ic_clear_bg" />

        <TextView
            android:id="@+id/btn_action_clear_cache"
            style="@style/SettingsItemStyle"
            android:text="@string/settings_clear_cache" 
            app:drawableStartCompat="@drawable/ic_clear" /> 
    </LinearLayout>

</LinearLayout>
