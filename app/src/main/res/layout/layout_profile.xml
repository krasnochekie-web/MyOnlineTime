<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundDark"
    android:paddingTop="@dimen/header_clearance"
    android:clipToPadding="false"
    android:scrollbars="none"
    android:paddingBottom="@dimen/bottom_nav_clearance">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"> 

        <!-- ВЕРХНИЙ БЛОК: Кнопка назад, Аватарка и Карандашик -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="16dp">

            <!-- Кнопка НАЗАД -->
            <ImageView
                android:id="@+id/profile_back_btn"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_math_arrow"
                android:tint="@color/textWhite"
                android:visibility="gone" />

            <!-- АВАТАРКА (Строго по центру) -->
            <ImageView
                android:id="@+id/profile_avatar"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_centerInParent="true"
                android:background="@drawable/bg_edit_circle"
                android:scaleType="centerCrop" />

            <!-- КАРАНДАШИК (Симметрично справа вверху) -->
            <ImageView
                android:id="@+id/btn_edit_profile"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_alignParentTop="true"
                android:layout_marginTop="16dp" 
                android:background="@drawable/bg_edit_circle"
                android:clickable="true"
                android:focusable="true"
                android:foreground="@drawable/ripple_circle"
                android:padding="6dp"
                android:src="@drawable/ic_edit"
                android:tint="@color/textWhite" />
        </RelativeLayout>

        <!-- НИКНЕЙМ -->
        <TextView
            android:id="@+id/profile_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="@string/guest"
            android:textColor="@color/textWhite"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- СТАТИСТИКА: 3 ОТДЕЛЬНЫЕ ПОДЛОЖКИ В ОДИН РЯД -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:baselineAligned="false">

            <!-- ВРЕМЯ ЗА НЕДЕЛЮ -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_card_glass"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:layout_marginRight="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="За неделю"
                    android:textColor="@color/textGray"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/profile_week_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="..."
                    android:textColor="@color/textWhite"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ПОДПИСЧИКИ -->
            <LinearLayout
                android:id="@+id/container_followers"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_card_glass"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:layout_marginHorizontal="4dp"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/followers"
                    android:textColor="@color/textGray"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/txt_followers_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="0"
                    android:textColor="@color/textWhite"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ПОДПИСКИ -->
            <LinearLayout
                android:id="@+id/container_following"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_card_glass"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:layout_marginLeft="4dp"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/following"
                    android:textColor="@color/textGray"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/txt_following_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="0"
                    android:textColor="@color/textWhite"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- О СЕБЕ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_glass"
            android:padding="16dp">
            <TextView
                android:id="@+id/profile_about"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/textGray"
                android:textSize="13sp"
                android:maxLines="6"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- КНОПКИ ДЕЙСТВИЙ -->
        <Button
            android:id="@+id/btn_follow"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_button_gray"
            android:text="@string/btn_follow"
            android:textColor="@color/burgundyRed"
            android:textStyle="bold"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_google_sign_in"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_button_gray"
            android:text="@string/btn_sign_in_google"
            android:textColor="@color/burgundyRed"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- ВКЛАДКИ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card_glass"
            android:orientation="horizontal">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center">
                <TextView
                    android:id="@+id/tab_top_apps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/top_apps"
                    android:textColor="@color/selector_grapefruit_white"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center">
                <TextView
                    android:id="@+id/tab_posts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/posts"
                    android:textColor="@color/selector_grapefruit_white"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- СПИСОК ПРИЛОЖЕНИЙ (Топ-10) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="30dp"
            android:background="@drawable/bg_card_glass"
            android:orientation="vertical"
            android:paddingTop="8dp">

            <LinearLayout
                android:id="@+id/profile_apps_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- КНОПКА "РАЗВЕРНУТЬ" (3 полоски) -->
            <ImageView
                android:id="@+id/btn_expand_apps"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackground"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:tint="@color/textGray"
                android:visibility="gone" />

            <!-- КНОПКА "СВЕРНУТЬ" (1 полоска / минус) -->
            <ImageView
                android:id="@+id/btn_collapse_apps"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackground"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:src="@android:drawable/btn_minus"
                android:tint="@color/textGray"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
