<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgDynamic"> 

    <ImageView
        android:id="@+id/profile_custom_background_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="@dimen/header_clearance"
        android:clipToPadding="false"
        android:scrollbars="none"
        android:isScrollContainer="true"
        android:nestedScrollingEnabled="true"
        android:paddingBottom="@dimen/bottom_nav_clearance">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"> 

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/profile_back_btn"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_math_arrow"
                    android:tint="@color/textWhiteStatic"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/profile_avatar"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_centerInParent="true"
                    android:background="@drawable/bg_edit_circle"
                    android:scaleType="centerCrop" />

                <ImageView
                    android:id="@+id/btn_edit_profile"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginTop="4dp" 
                    android:background="@drawable/bg_edit_circle"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/ripple_circle"
                    android:padding="6dp"
                    android:src="@drawable/ic_edit"
                    android:tint="@color/textDynamic" />
            </RelativeLayout>

            <TextView
                android:id="@+id/profile_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="@string/guest"
                android:textColor="@color/textDynamic"
                android:textSize="24sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:baselineAligned="false"
                android:alpha="0.85"> <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_app_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="12dp"
                    android:layout_marginRight="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="За неделю"
                        android:textColor="@color/textGrayDynamic"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/profile_week_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="..."
                        android:textColor="@color/textDynamic"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/container_followers"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_app_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="12dp"
                    android:layout_marginHorizontal="4dp"
                    android:clickable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/followers"
                        android:textColor="@color/textGrayDynamic"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/txt_followers_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0"
                        android:textColor="@color/textDynamic"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/container_following"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_app_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="12dp"
                    android:layout_marginLeft="4dp"
                    android:clickable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/following"
                        android:textColor="@color/textGrayDynamic"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/txt_following_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0"
                        android:textColor="@color/textDynamic"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_app_card"
                android:padding="16dp"
                android:alpha="0.85"> <TextView
                    android:id="@+id/profile_about"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/textDynamic"
                    android:textSize="13sp"
                    android:maxLines="6"
                    android:ellipsize="end" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_follow"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_button_gray"
                android:text="@string/btn_follow"
                android:textColor="@color/burgundyRed"
                android:textStyle="bold"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_google_sign_in"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_button_gray"
                android:text="@string/btn_sign_in_google"
                android:textColor="@color/burgundyRed"
                android:textStyle="bold"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_app_card"
                android:orientation="horizontal"
                android:alpha="0.85"> <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tab_top_apps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/top_apps"
                        android:textColor="@color/selector_tab_text" 
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tab_posts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/posts"
                        android:textColor="@color/selector_tab_text"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="30dp"
                android:background="@drawable/bg_app_card"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:alpha="0.85"> <LinearLayout
                    android:id="@+id/profile_apps_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <ImageView
                    android:id="@+id/btn_expand_apps"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="?android:attr/selectableItemBackground"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    android:tint="@color/textGrayDynamic"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/btn_collapse_apps"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="?android:attr/selectableItemBackground"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:src="@android:drawable/btn_minus"
                    android:tint="@color/textGrayDynamic"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
