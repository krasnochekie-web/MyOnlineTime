<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_profile_wallpaper"
    android:paddingTop="@dimen/header_clearance"
    android:clipToPadding="false"
    android:scrollbars="none"
    android:paddingBottom="@dimen/bottom_nav_clearance">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"> 
    
        <!-- ВЕРХНИЙ БЛОК: Наложение аватарки на карточку -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- КАРТОЧКА ПРОФИЛЯ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="32dp" 
                android:background="@drawable/bg_app_card"
                android:orientation="vertical"
                android:paddingTop="50dp" 
                android:paddingBottom="20dp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:elevation="0dp">
                
                <!-- Внутренности карточки (никнейм, статистика и т.д.) -->

                <!-- НИКНЕЙМ -->
                <TextView
                    android:id="@+id/profile_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/guest"
                    android:textColor="@color/textWhite"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- О СЕБЕ (Не вылезает за 3 строки) -->
                <TextView
                    android:id="@+id/profile_about"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:textColor="@color/textGray"
                    android:textSize="14sp"
                    android:maxLines="3"
                    android:ellipsize="end" />

                <!-- ТОНКАЯ ПОЛОСКА -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:background="#33FFFFFF" />

                <!-- СТАТИСТИКА В ОДИН РЯД -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <!-- ВРЕМЯ (Идеально ровно друг под другом) -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="За неделю"
                            android:textColor="@color/textGray"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/profile_week_time"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:layout_marginTop="4dp"
                            android:text="..."
                            android:textColor="@color/textWhite"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- ПОДПИСЧИКИ -->
                    <LinearLayout
                        android:id="@+id/container_followers"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/followers"
                            android:textColor="@color/textGray"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/txt_followers_count"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:layout_marginTop="4dp"
                            android:text="0"
                            android:textColor="@color/textWhite"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- ПОДПИСКИ -->
                    <LinearLayout
                        android:id="@+id/container_following"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/following"
                            android:textColor="@color/textGray"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/txt_following_count"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:layout_marginTop="4dp"
                            android:text="0"
                            android:textColor="@color/textWhite"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- АВАТАРКА (По центру, выпирает наверх) -->
            <ImageView
                android:id="@+id/profile_avatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_centerHorizontal="true"
                android:layout_alignParentTop="true"
                android:background="@drawable/bg_edit_circle"
                android:scaleType="centerCrop" />

            <!-- КАРАНДАШИК (В правом верхнем углу карточки) -->
            <ImageView
                android:id="@+id/btn_edit_profile"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentRight="true"
                android:layout_marginTop="56dp"
                android:layout_marginRight="48dp"
                android:background="@drawable/bg_edit_circle"
                android:clickable="true"
                android:padding="6dp"
                android:src="@drawable/ic_edit"
                android:tint="@color/textWhite" />
            
            <!-- КНОПКА НАЗАД (Слева, для чужих профилей) -->
             <ImageView
                android:id="@+id/profile_back_btn"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentLeft="true"
                android:layout_marginTop="56dp"
                android:layout_marginLeft="16dp"
                android:src="@drawable/ic_math_arrow"
                android:tint="@color/textWhite"
                android:visibility="gone" />

        </RelativeLayout>

        <!-- КНОПКИ ДЕЙСТВИЙ (Осталась только подписка и гугл вход) -->
        <Button
            android:id="@+id/btn_follow"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_button_gray"
            android:text="@string/btn_follow"
            android:textColor="@color/primaryGrapefruit"
            android:textStyle="bold"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_google_sign_in"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_button_gray"
            android:text="@string/btn_sign_in_google"
            android:textColor="@color/primaryGrapefruit"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- ВКЛАДКИ (На серой подложке-таблетке) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:background="@drawable/bg_tabs_container"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center">
                <TextView
                    android:id="@+id/tab_top_apps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/top_apps"
                    android:textColor="@color/selector_grapefruit_white"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center">
                <TextView
                    android:id="@+id/tab_posts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/posts"
                    android:textColor="@color/selector_grapefruit_white"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- ОТДЕЛЬНАЯ КАРТОЧКА СО СПИСКОМ (Топ-10) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginBottom="30dp"
            android:background="@drawable/bg_app_card"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <!-- Внутренности карточки со списком -->

            <LinearLayout
                android:id="@+id/profile_apps_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- КНОПКА "РАЗВЕРНУТЬ" (3 полоски) -->
            <ImageView
                android:id="@+id/btn_expand_apps"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackground"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:tint="@color/textGray"
                android:visibility="gone" />

            <!-- КНОПКА "СВЕРНУТЬ" (1 полоска / минус) -->
            <ImageView
                android:id="@+id/btn_collapse_apps"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackground"
                android:padding="16dp"
                android:src="@android:drawable/btn_minus"
                android:tint="@color/textGray"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
