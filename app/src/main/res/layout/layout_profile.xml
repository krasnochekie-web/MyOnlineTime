<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_profile_wallpaper"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- КНОПКА НАЗАД (Для чужих профилей) -->
        <ImageView
            android:id="@+id/profile_back_btn"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_math_arrow"
            android:tint="@color/textWhite"
            android:visibility="gone" 
            android:layout_marginBottom="12dp"/>

        <!-- СТРОКА: АВАТАР И СТАТИСТИКА -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <!-- Аватарка слева -->
            <ImageView
                android:id="@+id/profile_avatar"
                android:layout_width="86dp"
                android:layout_height="86dp"
                android:background="@drawable/bg_edit_circle"
                android:scaleType="centerCrop"/> 

            <!-- Блок Статистики справа -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginLeft="16dp"
                android:gravity="center">

                <!-- Время -->
                <LinearLayout android:layout_weight="1" android:orientation="vertical" android:layout_width="0dp" android:layout_height="wrap_content" android:gravity="center">
                    <TextView android:id="@+id/profile_week_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="..." android:textSize="18sp" android:textColor="@color/textWhite" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="За неделю" android:textColor="@color/textGray" android:textSize="12sp" android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- Подписчики -->
                <LinearLayout android:id="@+id/container_followers" android:layout_weight="1" android:orientation="vertical" android:layout_width="0dp" android:layout_height="wrap_content" android:clickable="true" android:gravity="center">
                    <TextView android:id="@+id/txt_followers_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="18sp" android:textColor="@color/textWhite" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/followers" android:textColor="@color/textGray" android:textSize="12sp" android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- Подписки -->
                <LinearLayout android:id="@+id/container_following" android:layout_weight="1" android:orientation="vertical" android:layout_width="0dp" android:layout_height="wrap_content" android:clickable="true" android:gravity="center">
                    <TextView android:id="@+id/txt_following_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="18sp" android:textColor="@color/textWhite" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/following" android:textColor="@color/textGray" android:textSize="12sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ИМЯ И О СЕБЕ -->
        <TextView
            android:id="@+id/profile_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/guest"
            android:textSize="18sp"
            android:textColor="@color/textWhite"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/profile_about"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/textWhite"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:maxLines="3"
            android:ellipsize="end"/>

        <!-- ШИРОКАЯ КНОПКА РЕДАКТИРОВАНИЯ (С карандашом) -->
        <LinearLayout
            android:id="@+id/btn_edit_profile"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="@drawable/bg_button_gray"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:clickable="true">
            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_edit" android:tint="@color/textWhite" android:layout_marginRight="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/edit_profile_title" android:textColor="@color/textWhite" android:textStyle="bold" android:textSize="14sp"/>
        </LinearLayout>

        <!-- ДРУГИЕ КНОПКИ (Чужой профиль / Выход) -->
        <Button android:id="@+id/btn_follow" android:layout_width="match_parent" android:layout_height="36dp" android:text="@string/btn_follow" android:background="@drawable/bg_button_gray" android:textColor="@color/primaryGrapefruit" android:layout_marginTop="8dp" android:textStyle="bold" android:textSize="14sp" android:visibility="gone"/>
        <Button android:id="@+id/btn_google_sign_in" android:layout_width="match_parent" android:layout_height="48dp" android:text="@string/btn_sign_in_google" android:background="@drawable/bg_button_gray" android:textColor="@color/primaryGrapefruit" android:layout_marginTop="16dp" android:textStyle="bold" android:visibility="gone"/>
        <Button android:id="@+id/btn_sign_out" android:layout_width="match_parent" android:layout_height="48dp" android:text="@string/btn_sign_out" android:visibility="gone" android:background="@drawable/bg_button_gray" android:textColor="@color/primaryGrapefruit" android:layout_marginTop="16dp" android:textStyle="bold"/>

        <!-- ВКЛАДКИ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center">
                <TextView
                    android:id="@+id/tab_top_apps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/top_apps"
                    android:textColor="@color/selector_grapefruit_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center">
                <TextView
                    android:id="@+id/tab_posts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/posts"
                    android:textColor="@color/selector_grapefruit_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- ОТДЕЛЬНАЯ КАРТОЧКА СО СПИСКОМ (Топ-10) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="30dp"
            android:background="@drawable/bg_app_card"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:id="@+id/profile_apps_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <ImageView
                android:id="@+id/btn_expand_apps"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackground"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:tint="@color/textGray"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
