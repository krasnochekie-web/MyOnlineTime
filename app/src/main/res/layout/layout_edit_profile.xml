<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgDynamic"> 

    <ImageView
        android:id="@+id/edit_profile_custom_background_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <VideoView
        android:id="@+id/edit_profile_custom_background_video"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:visibility="gone" />

    <LinearLayout 
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="@dimen/header_clearance"
        android:clipToPadding="false">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingHorizontal="16dp" 
                android:paddingBottom="20dp"> 

                <ImageView
                    android:id="@+id/edit_avatar_preview"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_edit_circle"
                    android:src="@android:drawable/sym_def_app_icon"
                    android:scaleType="centerCrop"
                    android:padding="0dp"/>

                <EditText
                    android:id="@+id/input_nickname"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@null"
                    android:textColor="@color/textDynamic" 
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:hint="@string/label_nickname"
                    android:textColorHint="@color/textGrayDynamic"
                    android:paddingBottom="4dp"
                    android:gravity="center"
                    android:singleLine="true"/>

                <View 
                    android:layout_width="160dp" 
                    android:layout_height="1dp" 
                    android:background="@color/textGrayDynamic"
                    android:layout_marginBottom="32dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/btn_change_photo"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_button_gray"
                        android:foreground="@drawable/ripple_button_gray"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true" 
                        android:alpha="0.85">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/btn_change_photo"
                            android:textColor="@color/burgundyRed" 
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btn_change_background"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_button_gray"
                        android:foreground="@drawable/ripple_button_gray"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true" 
                        android:alpha="0.85">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/btn_change_background"
                            android:textColor="@color/burgundyRed" 
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_about"
                        android:textColor="@color/textGrayDynamic" 
                        android:textSize="11sp"
                        android:layout_marginBottom="8dp"/>

                    <EditText
                        android:id="@+id/input_about"
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:background="@drawable/bg_input_field"
                        android:textColor="@color/textDynamic" 
                        android:textSize="12sp"
                        android:gravity="top|left"
                        android:padding="16dp"
                        android:alpha="0.85"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btn_save_changes"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/btn_save_changes"
                    android:background="@drawable/bg_button_grapefruit"
                    android:clickable="true" 
                    android:focusable="true"
                    android:foreground="@drawable/ripple_button_grapefruit"
                    android:textColor="@color/textWhiteStatic" 
                    android:textStyle="bold"
                    android:layout_marginTop="30dp"
                    android:layout_marginBottom="20dp"
                    android:alpha="0.95"/>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>
