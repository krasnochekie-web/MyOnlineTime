<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    android:background="#121212">

    
    <!-- ШАПКА ПРИЛОЖЕНИЯ (Строго по центру, в рамке) -->
    <RelativeLayout
        android:id="@+id/app_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_header"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingBottom="12dp"
        android:paddingTop="40dp" 
        android:elevation="0dp">

        <!-- Кнопка НАЗАД (Слева) -->
        <ImageView
            android:id="@+id/header_back_btn"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_math_arrow"
            android:tint="@color/textWhite"
            android:visibility="gone"
            android:clickable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"/>

        <!-- ЗАГОЛОВОК (Уменьшен в 1.5 раза, в рамке, ровно по центру) -->
        <TextView
            android:id="@+id/header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:background="@drawable/bg_title_border"
            android:text="@string/app_name"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/textWhite"/>

        <!-- Иконка Настройки (Справа) -->
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_settings"
            android:tint="@color/textWhite"/>
    </RelativeLayout>
    
    <LinearLayout
        android:id="@+id/bottom_nav_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#1E1E1E"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="40dp" 
        android:baselineAligned="false">

        
        <LinearLayout 
            android:id="@+id/nav_feed" 
            android:layout_width="0dp" 
            android:layout_height="56dp" 
            android:layout_weight="1" 
            android:orientation="vertical" 
            android:gravity="center" 
            android:clickable="true" 
            android:background="@drawable/bg_ripple_dark_theme">
            <ImageView 
                android:id="@+id/icon_feed" 
                android:layout_width="24dp" 
                android:layout_height="24dp" 
                android:src="@drawable/ic_nav_feed"
                android:tint="@color/nav_color"/>
            <TextView 
                android:id="@+id/text_feed" 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content" 
                android:text="@string/feed" 
                android:textSize="12sp" 
                android:textColor="@color/nav_color" 
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        
        <LinearLayout 
            android:id="@+id/nav_search" 
            android:layout_width="0dp" 
            android:layout_height="56dp" 
            android:layout_weight="1" 
            android:orientation="vertical" 
            android:gravity="center" 
            android:clickable="true" 
            android:background="@drawable/bg_ripple_dark_theme">
            <ImageView 
                android:id="@+id/icon_search" 
                android:layout_width="24dp" 
                android:layout_height="24dp" 
                android:src="@drawable/ic_nav_search"
                android:tint="@color/nav_color"/>
            <TextView 
                android:id="@+id/text_search" 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content" 
                android:text="@string/find" 
                android:textSize="12sp" 
                android:textColor="@color/nav_color" 
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        
        <LinearLayout 
            android:layout_width="0dp" 
            android:layout_height="56dp" 
            android:layout_weight="1" 
            android:gravity="center">
            <LinearLayout 
                android:id="@+id/nav_add" 
                android:layout_width="48dp" 
                android:layout_height="36dp" 
                android:background="@drawable/bg_nav_center" 
                android:gravity="center" 
                android:clickable="true">
                <ImageView 
                    android:layout_width="24dp" 
                    android:layout_height="24dp" 
                    android:src="@drawable/ic_nav_plus"
                    android:tint="@color/nav_color"/>
            </LinearLayout>
        </LinearLayout>

        
        <LinearLayout 
            android:id="@+id/nav_usage" 
            android:layout_width="0dp" 
            android:layout_height="56dp" 
            android:layout_weight="1" 
            android:orientation="vertical" 
            android:gravity="center" 
            android:clickable="true" 
            android:background="@drawable/bg_ripple_dark_theme">
            <ImageView 
                android:id="@+id/icon_usage" 
                android:layout_width="24dp" 
                android:layout_height="24dp" 
                android:src="@drawable/ic_nav_time"
                android:tint="@color/nav_color"/>
            <TextView 
                android:id="@+id/text_usage" 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content" 
                android:text="@string/time" 
                android:textSize="12sp" 
                android:textColor="@color/nav_color" 
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        
        <LinearLayout 
            android:id="@+id/nav_profile" 
            android:layout_width="0dp" 
            android:layout_height="56dp" 
            android:layout_weight="1" 
            android:orientation="vertical" 
            android:gravity="center" 
            android:clickable="true" 
            android:background="@drawable/bg_ripple_dark_theme">
            <ImageView 
                android:id="@+id/icon_profile" 
                android:layout_width="24dp" 
                android:layout_height="24dp" 
                android:src="@drawable/ic_nav_profile"
                android:tint="@color/nav_color"/>
            <TextView 
                android:id="@+id/text_profile" 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content" 
                android:text="@string/me" 
                android:textSize="12sp" 
                android:textColor="@color/nav_color" 
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/app_header"
        android:layout_above="@+id/bottom_nav_container" />

</RelativeLayout>
