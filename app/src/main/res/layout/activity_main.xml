<?xml version="1.0" encoding="utf-8"?>
<!-- ДОБАВЛЕН ID main_root ДЛЯ УПРАВЛЕНИЯ ФОНОМ -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main_root" 
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    android:background="#121212">

    <!-- ШАПКА ПРИЛОЖЕНИЯ (Стабильный LinearLayout) -->
    <LinearLayout
        android:id="@+id/app_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_header"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="16dp"
        android:paddingRight="20dp"
        android:paddingBottom="8dp"
        android:paddingTop="36dp" 
        android:elevation="0dp">

        <!-- Кнопка НАЗАД (Скрыта по умолчанию) -->
        <ImageView
            android:id="@+id/header_back_btn"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_math_arrow"
            android:tint="@color/textWhite"
            android:visibility="gone"
            android:clickable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:layout_marginRight="16dp"/>

        <!-- БЕЗОПАСНАЯ РАСПОРКА 1 (Толкает текст в центр) -->
        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <!-- ЗАГОЛОВОК (По центру, узкий) -->
        <TextView
            android:id="@+id/header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:gravity="center"
            android:background="@drawable/bg_title_border"
            android:text="@string/app_name"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/textWhite"/>

        <!-- БЕЗОПАСНАЯ РАСПОРКА 2 (Толкает настройки вправо) -->
        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <!-- Иконка Настройки (В правом углу) -->
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_settings"
            android:tint="@color/textWhite"
            android:layout_marginLeft="16dp"/>

    </LinearLayout>

    <!-- КОНТЕЙНЕР ДЛЯ ЭКРАНОВ -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_nav_container" />

    <!-- НИЖНЕЕ МЕНЮ НАВИГАЦИИ -->
    <LinearLayout
        android:id="@+id/bottom_nav_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#1E1E1E"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="40dp" 
        android:baselineAligned="false">

        <!-- Вкладка 1: Лента -->
        <LinearLayout 
            android:id="@+id/nav_feed" 
            android:layout_width="0dp" 
            android:layout_height="56dp" 
            android:layout_weight="1" 
            android:orientation="vertical" 
            android:gravity="center" 
            android:clickable="true" 
            android:background="@drawable/bg_ripple_dark_theme">

            <ImageView 
                android:id="@+id/icon_feed" 
                android:layout_width="24dp" 
                android:layout_height="24dp" 
                android:src="@drawable/ic_nav_feed"
                android:tint="@color/selector_grapefruit_white"/>

            <TextView 
                android:id="@+id/text_feed" 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content" 
                android:text="@string/feed" 
                android:textSize="12sp" 
                android:textColor="@color/selector_grapefruit_white" 
                android:layout_marginTop="2dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Вкладка 2: Поиск -->
        <LinearLayout 
            android:id="@+id/nav_search" 
            android:layout_width="0dp" 
            android:layout_height="56dp" 
            android:layout_weight="1" 
            android:orientation="vertical" 
            android:gravity="center" 
            android:clickable="true" 
            android:background="@drawable/bg_ripple_dark_theme">

            <ImageView 
                android:id="@+id/icon_search" 
                android:layout_width="24dp" 
                android:layout_height="24dp" 
                android:src="@drawable/ic_nav_search"
                android:tint="@color/selector_grapefruit_white"/>

            <TextView 
                android:id="@+id/text_search" 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content" 
                android:text="@string/find" 
                android:textSize="12sp" 
                android:textColor="@color/selector_grapefruit_white" 
                android:layout_marginTop="2dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Вкладка 3: Центральная кнопка (+) -->
        <LinearLayout 
            android:layout_width="0dp" 
            android:layout_height="56dp" 
            android:layout_weight="1" 
            android:gravity="center">

            <LinearLayout 
                android:id="@+id/nav_add" 
                android:layout_width="48dp" 
                android:layout_height="36dp" 
                android:gravity="center" 
                android:clickable="true">

                <ImageView 
                    android:layout_width="24dp" 
                    android:layout_height="24dp" 
                    android:src="@drawable/ic_nav_plus"
                    android:tint="@color/textWhite"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Вкладка 4: Время -->
        <LinearLayout 
            android:id="@+id/nav_usage" 
            android:layout_width="0dp" 
            android:layout_height="56dp" 
            android:layout_weight="1" 
            android:orientation="vertical" 
            android:gravity="center" 
            android:clickable="true" 
            android:background="@drawable/bg_ripple_dark_theme">

            <ImageView 
                android:id="@+id/icon_usage" 
                android:layout_width="24dp" 
                android:layout_height="24dp" 
                android:src="@drawable/ic_nav_time"
                android:tint="@color/selector_grapefruit_white"/>

            <TextView 
                android:id="@+id/text_usage" 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content" 
                android:text="@string/time" 
                android:textSize="12sp" 
                android:textColor="@color/selector_grapefruit_white" 
                android:layout_marginTop="2dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Вкладка 5: Профиль -->
        <LinearLayout 
            android:id="@+id/nav_profile" 
            android:layout_width="0dp" 
            android:layout_height="56dp" 
            android:layout_weight="1" 
            android:orientation="vertical" 
            android:gravity="center" 
            android:clickable="true" 
            android:background="@drawable/bg_ripple_dark_theme">

            <ImageView 
                android:id="@+id/icon_profile" 
                android:layout_width="24dp" 
                android:layout_height="24dp" 
                android:src="@drawable/ic_nav_profile"
                android:tint="@color/selector_grapefruit_white"/>

            <TextView 
                android:id="@+id/text_profile" 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content" 
                android:text="@string/me" 
                android:textSize="12sp" 
                android:textColor="@color/selector_grapefruit_white" 
                android:layout_marginTop="2dp"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
