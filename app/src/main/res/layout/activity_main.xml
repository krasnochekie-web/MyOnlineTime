<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundDark">

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ШАПКА -->
    <LinearLayout
        android:id="@+id/app_header"
        android:clipToOutline="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_header"
        android:orientation="vertical"
        fitsSystemWindows="true"
        android:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingTop="20dp">

            <ImageView
                android:id="@+id/header_back_btn"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginRight="10dp"
                android:src="@drawable/ic_math_arrow"
                android:tint="@color/textWhite"
                android:visibility="gone"
                android:clickable="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"/>

            <TextView
                android:id="@+id/header_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/textWhite"/>
            
            <!-- Иконка настроек отсюда УДАЛЕНА -->
        </LinearLayout>
    </LinearLayout>

    <!-- ПЛАВАЮЩЕЕ НИЖНЕЕ МЕНЮ НАВИГАЦИИ -->
    <LinearLayout
        android:id="@+id/bottom_nav_container"
        android:layout_width="match_parent"
        android:layout_height="64dp" 
        android:layout_alignParentBottom="true"
        android:layout_marginLeft="10dp" 
        android:layout_marginRight="10dp"
        android:layout_marginBottom="12dp" 
        android:background="@drawable/bg_floating_bottom_nav"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:baselineAligned="false"
        android:elevation="20dp">

        <!-- Вкладка 1: Лента -->
        <LinearLayout android:id="@+id/nav_feed" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:clickable="true" android:background="@drawable/bg_ripple_circle_dark">
            <ImageView android:id="@+id/icon_feed" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_nav_feed" android:tint="@color/selector_grapefruit_white"/>
        </LinearLayout>

        <!-- Вкладка 2: Поиск -->
        <LinearLayout android:id="@+id/nav_search" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:clickable="true" android:background="@drawable/bg_ripple_circle_dark">
            <ImageView android:id="@+id/icon_search" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_nav_search" android:tint="@color/selector_grapefruit_white"/>
        </LinearLayout>

        <!-- Вкладка 3: ПРОФИЛЬ (По центру) -->
        <LinearLayout android:id="@+id/nav_profile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:clickable="true">
            <ImageView
                android:id="@+id/icon_profile"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="2dp" 
                android:background="@drawable/bg_profile_avatar_border"
                android:src="@drawable/ic_nav_profile"/>
        </LinearLayout>

        <!-- Вкладка 4: Время -->
        <LinearLayout android:id="@+id/nav_usage" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:clickable="true" android:background="@drawable/bg_ripple_circle_dark">
            <ImageView android:id="@+id/icon_usage" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_nav_time" android:tint="@color/selector_grapefruit_white"/>
        </LinearLayout>

        <!-- Вкладка 5: НАСТРОЙКИ (Вместо старого профиля) -->
        <LinearLayout android:id="@+id/nav_settings" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:clickable="true" android:background="@drawable/bg_ripple_circle_dark">
            <ImageView android:id="@+id/icon_settings" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_settings" android:tint="@color/selector_grapefruit_white"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Экран разрешений поверх всего -->
    <include 
        layout="@layout/layout_permission_required"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/app_header" 
        android:elevation="30dp"
        android:visibility="gone" /> 

</RelativeLayout>
