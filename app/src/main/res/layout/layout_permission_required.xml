<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/permission_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/backgroundDark"
    android:clickable="true"
    android:focusable="true"
    android:elevation="20dp"
    android:padding="24dp">

    <!-- Главный заголовок сверху -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/permission_title"
        android:textColor="@color/textWhite"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="32dp"/>

    <!-- Скриншот внутри экрана с закруглениями и обводкой -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_image_border"
        android:clipToOutline="true"
        android:layout_marginBottom="32dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/img_permission_example" />
    </LinearLayout>

    <!-- Текст с выделенными красным фразами -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/permission_rationale"
        android:textColor="@color/textWhite"
        android:textSize="14sp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="32dp"/>

    <!-- Кнопка Включить доступ -->
    <Button
        android:id="@+id/btn_grant_permission"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/btn_enable_access"
        android:background="@drawable/bg_button_grapefruit"
        android:clickable="true"
        android:focusable="true"
        android:foreground="@drawable/ripple_button_grapefruit"
        android:textColor="@color/textWhite"
        android:textStyle="bold"
        android:textSize="14sp"/>

</LinearLayout>
